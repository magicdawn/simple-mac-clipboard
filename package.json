{
  "name": "simple-mac-clipboard",
  "type": "module",
  "version": "1.2.3",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "description": "simple mac clipboard for node & electron",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/simple-mac-clipboard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magicdawn/simple-mac-clipboard.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/simple-mac-clipboard/issues"
  },
  "keywords": [
    "clip",
    "clipboard",
    "mac-clipboard"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./build/*": "./build/*",
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "simple_mac_clipboard.node"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "dev:generate-compile_commands": "bear -- node-gyp rebuild",
    "build:addon": "node-gyp rebuild",
    "build:fat-addon": "tsx ./scripts/build-universal-addon.ts",
    "build:tsdown": "tsdown",
    "build": "conc pnpm:build:addon pnpm:build:tsdown",
    "test": "vitest --run --fileParallelism=false",
    "prepublishOnly": "pnpm build:fat-addon && pnpm build:tsdown && pnpm test",
    "test-with-debug": "pnpm build:addon --debug && pnpm test",
    "test-cover": "pnpm test -- --coverage"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.4.0"
  },
  "devDependencies": {
    "@magicdawn/eslint-config": "^1.6.6",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/bindings": "^1.5.5",
    "@types/node": "^25.9.2",
    "codecov": "^3.8.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "node-abi": "^4.31.0",
    "nyc": "^18.0.0",
    "prebuild": "^13.0.1",
    "prettier": "^3.8.4",
    "semver": "^7.8.4",
    "tsd": "^0.33.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,less,vue}": [
      "prettier --write",
      "git add"
    ],
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "gypfile": false,
  "directories": {
    "test": "test"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
